# Required: Anthropic API Key for Claude
ANTHROPIC_API_KEY=sk-ant-...

# Required: Craft MCP Server URL
# Format: http://localhost:3000/v1/links/{secretLinkId}/mcp
CRAFT_MCP_URL=http://localhost:3000/v1/links/YOUR_SECRET_LINK_ID/mcp

# Required: Bearer token for MCP authentication
CRAFT_MCP_TOKEN=your-bearer-token-here

# OpenLLM Environment Connection (auto-synthesizes a default LLM connection at startup)
# When OPENLLM_HOST is set it takes priority over LLM_BASE_URL as the default connection.
# Required: base URL of the OpenLLM deployment (no trailing slash).
# The app injects the SSO session token as the Authorization header via the network
# interceptor; no API key is stored. Onboarding is skipped.
# OPENLLM_HOST=https://openllm.internal
# Optional: comma-separated model list; first entry becomes the default model.
# OPENLLM_MODELS=llama-3,mistral-7b
# Optional: display name shown in Settings > AI (default: "OpenLLM").
# OPENLLM_CONNECTION_NAME=OpenLLM

# Environment Connection (generic OpenAI Chat Completions–compatible endpoint)
# Used when OPENLLM_HOST is not set. The app uses the SSO session token as the
# Authorization header (no Bearer prefix). Onboarding is skipped.
LLM_BASE_URL=https://your-llm-endpoint/v1
# Optional: default model name exposed by the endpoint.
# LLM_MODEL=your-model-name
# Optional: display name shown for the Environment connection in Settings > AI.
# LLM_CONNECTION_NAME=Environment

# MDP SSO Configuration
# OIDC authorization endpoint used to start the system-browser login flow.
MDP_AUTH_URL=https://auth.example.com/oauth/authorize
# OAuth client_id for the desktop app.
MDP_CLIENT_ID=your-mdp-client-id
# Base URL for /api/mdp/auth/* calls.
MDP_API_URL=https://mdp.example.com
# Self-hosted OAuth relay URL used as the OIDC redirect_uri.
# Must be pre-registered with the OIDC provider. See ADR 0008.
MDP_RELAY_URL=https://your-relay.example.com/auth/callback
# Development only: set to 1 to inject a mock SSO session and skip login.
# Ignored in packaged production builds.
CRAFT_DISABLE_SSO=0
# Set to 1 to enforce CSRF nonce validation on the SSO callback.
# When unset, the state param is omitted from the auth URL and not checked on return.
MDP_ENABLE_SSO_STATE_CHECK=0

# Google OAuth Configuration (OPTIONAL - for development/testing only)
# For production use, users should provide their own credentials via source configuration.
# These env vars serve as a fallback if source config doesn't specify credentials.
# See README_FOR_OSS.md for setup instructions.
# To create credentials: Google Cloud Console > APIs & Services > Credentials > Desktop app
# GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret

# Slack OAuth Configuration (for Slack workspace integration)
# Get these from Slack API > Your Apps > OAuth & Permissions
SLACK_OAUTH_CLIENT_ID=your-slack-client-id
SLACK_OAUTH_CLIENT_SECRET=your-slack-client-secret

# Microsoft OAuth Configuration (for Outlook, OneDrive, Teams integration)
# Get these from Azure Portal > App Registrations
# Note: Create a "Mobile and desktop applications" platform OAuth client - PKCE is used so no client_secret is needed
MICROSOFT_OAUTH_CLIENT_ID=your-microsoft-client-id

# Sentry Error Tracking (captures crashes and chat/SDK errors)
# Get the ingest URL from Sentry > Project Settings > Client Keys (DSN)
SENTRY_ELECTRON_INGEST_URL=https://your-public-key@o0.ingest.sentry.io/0

# Release upload server (used by scripts/upload.ts)
# POST multipart/form-data with field "file", destination path as ?path=... query param
RELEASE_UPLOAD_URL=https://update.yourdomain.com/api/release/upload
RELEASE_UPLOAD_TOKEN=your-upload-token

# Linear Issue Tracker (used by .afk/linear.ts)
# Get your API key from Linear > Settings > API > Personal API keys
LINEAR_API_KEY=lin_api_...
