# Sprint Task Lists - Environment Variables for Claude Code Collaboration
# Format: CLAUDE_CODE_TASK_LIST_ID=identifier
# Usage: Export these variables and reference in Claude Code sessions for multi-agent collaboration

# Sprint 1: GitHub Integration & Daily Reports (COMPLETED)
CLAUDE_CODE_TASK_LIST_ID_SPRINT1=github-integration-sprint1

# Sprint 2: Intelligent Triage Engine (CURRENT - Feb 6-19, 2026)
CLAUDE_CODE_TASK_LIST_ID_SPRINT2=intelligent-triage-engine-sprint2

# Sprint 3: Orchestration & Approval (PLANNED - Feb 20 - Mar 5)
CLAUDE_CODE_TASK_LIST_ID_SPRINT3=orchestration-approval-sprint3

# Sprint 4: Learning System & Metrics (PLANNED - Mar 6-19)
CLAUDE_CODE_TASK_LIST_ID_SPRINT4=learning-system-sprint4

# Sprint 5: Beta Launch & Iteration (PLANNED - Mar 20 - Apr 2)
CLAUDE_CODE_TASK_LIST_ID_SPRINT5=beta-launch-sprint5

# Sprint 6: Scale to 200 Teams (PLANNED - Apr 3-16)
CLAUDE_CODE_TASK_LIST_ID_SPRINT6=scale-200-teams-sprint6

# Sprint 7: Revenue & Growth (PLANNED - Apr 17-30)
CLAUDE_CODE_TASK_LIST_ID_SPRINT7=revenue-growth-sprint7

# Sprint 8: Final Push to 500 Teams (PLANNED - May 1-31)
CLAUDE_CODE_TASK_LIST_ID_SPRINT8=final-push-500-teams-sprint8

# Load Sprint 2 tasks
export CURRENT_SPRINT=2
export CURRENT_SPRINT_TASK_LIST=$CLAUDE_CODE_TASK_LIST_ID_SPRINT2
