{
  "projectName": "craft-agent",
  "version": "0.2.22",
  "description": "Claude Code-like agent for Craft documents",
  "techStack": {
    "runtime": "Bun",
    "frameworks": [
      "Electron",
      "React",
      "Vite",
      "Tailwind CSS v4"
    ],
    "libraries": [
      "@anthropic-ai/claude-agent-sdk",
      "jotai",
      "shadcn/ui"
    ]
  },
  "architecture": {
    "type": "Monorepo",
    "workspaces": [
      "apps/electron",
      "apps/viewer",
      "packages/core",
      "packages/shared",
      "packages/ui"
    ]
  },
  "conventions": {
    "messageIds": "generateMessageId()",
    "packageManager": "bun"
  }
}
